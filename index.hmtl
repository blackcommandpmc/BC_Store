<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cyber Bar Store</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        :root {
            /* REPLACE IMAGE URL HERE */
            --bg-image: url('https://images.unsplash.com/photo-1614850523296-d8c1af93d400?q=80&w=2070');
        }

        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: var(--bg-image) no-repeat center center fixed;
            background-size: cover;
            color: white;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.9);
        }

        .hidden { display: none !important; }

        /* Auth Screen */
        #auth-screen {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            background: rgba(0,0,0,0.6);
        }

        /* Store Layout */
        #store-screen {
            display: grid;
            grid-template-columns: 1fr 350px;
            height: 100vh;
        }

        .products-container {
            overflow-y: auto;
            padding: 20px;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 20px;
        }

        .cart-panel {
            background: rgba(0, 0, 0, 0.8);
            border-left: 1px solid #444;
            padding: 20px;
            display: flex;
            flex-direction: column;
        }

        .product-card {
            background: rgba(255, 255, 255, 0.1);
            padding: 10px;
            border-radius: 8px;
            text-align: center;
            backdrop-filter: blur(5px);
        }

        .product-card img { width: 100%; border-radius: 4px; }

        /* Modal Styles */
        .modal {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: #222;
            padding: 30px;
            border-radius: 10px;
            z-index: 100;
        }

        input, select, button {
            display: block;
            width: 100%;
            margin: 10px 0;
            padding: 10px;
            border-radius: 5px;
            border: none;
        }

        button { cursor: pointer; background: #2ecc71; color: white; font-weight: bold; }
        .admin-btn { background: #e74c3c; }
    </style>
</head>
<body>

    <div id="auth-screen">
        <h1>BEM-VINDO À LOJA</h1>
        <input type="email" id="login-email" placeholder="E-mail">
        <input type="password" id="login-pass" placeholder="Senha">
        <button onclick="login()">Entrar</button>
        <button style="background: #3498db;" onclick="toggleModal('reg-modal', true)">Registrar-se</button>
    </div>

    <div id="reg-modal" class="modal hidden">
        <h2>Criar Conta</h2>
        <input type="text" id="reg-nome" placeholder="Nome in-game">
        <input type="text" id="reg-tel" placeholder="Telefone in-game">
        <input type="email" id="reg-email" placeholder="E-mail">
        <input type="password" id="reg-pass" placeholder="Senha">
        <button onclick="register()">Finalizar Cadastro</button>
        <button onclick="toggleModal('reg-modal', false)">Cancelar</button>
    </div>

    <div id="store-screen" class="hidden">
        <div class="main-content">
            <div id="admin-controls" class="hidden" style="padding: 20px; background: rgba(0,0,0,0.5);">
                <h3>Painel Admin</h3>
                <input type="text" id="p-name" placeholder="Nome do Produto">
                <input type="number" id="p-price" placeholder="Preço">
                <input type="text" id="p-img" placeholder="Link da Imagem">
                <select id="p-cat">
                    <option>Pistolas</option>
                    <option>Submetralhadoras</option>
                    <option>Fuzis</option>
                    <option>Especiais</option>
                </select>
                <button class="admin-btn" onclick="addProduct()">Adicionar Item</button>
            </div>
            <div id="products-list" class="products-container"></div>
        </div>

        <div class="cart-panel">
            <h2>Carrinho</h2>
            <div id="cart-items" style="flex-grow: 1;"></div>
            <div id="cart-total">Total: $0</div>
            <button onclick="checkout()">Finalizar no Discord</button>
            <button onclick="logout()" style="background: #555;">Sair</button>
        </div>
    </div>

    <script>
        // CONFIGURAÇÃO SUPABASE
        const SUPABASE_URL = 'YOUR_SUPABASE_URL';
        const SUPABASE_KEY = 'YOUR_SUPABASE_ANON_KEY';
        const DISCORD_WEBHOOK = 'YOUR_DISCORD_WEBHOOK_URL';
        
        const supabase = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
        let cart = [];
        let currentUser = null;

        function toggleModal(id, show) {
            document.getElementById(id).classList.toggle('hidden', !show);
        }

        async function register() {
            const email = document.getElementById('reg-email').value;
            const password = document.getElementById('reg-pass').value;
            const metadata = {
                nome_ingame: document.getElementById('reg-nome').value,
                tel_ingame: document.getElementById('reg-tel').value,
                role: 'customer'
            };

            const { data, error } = await supabase.auth.signUp({
                email, password, options: { data: metadata }
            });

            if (error) alert(error.message);
            else { alert("Sucesso! Verifique seu email."); toggleModal('reg-modal', false); }
        }

        async function login() {
            const email = document.getElementById('login-email').value;
            const password = document.getElementById('login-pass').value;

            const { data, error } = await supabase.auth.signInWithPassword({ email, password });

            if (error) alert(error.message);
            else {
                currentUser = data.user;
                showStore();
            }
        }

        function showStore() {
            document.getElementById('auth-screen').classList.add('hidden');
            document.getElementById('store-screen').classList.remove('hidden');
            
            if (currentUser.user_metadata.role === 'admin') {
                document.getElementById('admin-controls').classList.remove('hidden');
            }
            loadProducts();
        }

        async function loadProducts() {
            const { data, error } = await supabase.from('products').select('*');
            const list = document.getElementById('products-list');
            list.innerHTML = '';
            data.forEach(p => {
                list.innerHTML += `
                    <div class="product-card">
                        <img src="${p.image_url}" alt="${p.name}">
                        <h4>${p.name}</h4>
                        <p>${p.category}</p>
                        <p>$${p.price}</p>
                        <button onclick="addToCart('${p.name}', ${p.price})">Comprar</button>
                        ${currentUser.user_metadata.role === 'admin' ? `<button class="admin-btn" onclick="deleteProduct('${p.id}')">Excluir</button>` : ''}
                    </div>
                `;
            });
        }

        async function addProduct() {
            const product = {
                name: document.getElementById('p-name').value,
                price: document.getElementById('p-price').value,
                image_url: document.getElementById('p-img').value,
                category: document.getElementById('p-cat').value
            };
            await supabase.from('products').insert([product]);
            loadProducts();
        }

        async function deleteProduct(id) {
            await supabase.from('products').delete().eq('id', id);
            loadProducts();
        }

        function addToCart(name, price) {
            cart.push({ name, price });
            updateCartUI();
        }

        function updateCartUI() {
            const items = document.getElementById('cart-items');
            items.innerHTML = cart.map(i => `<div>${i.name} - $${i.price}</div>`).join('');
            const total = cart.reduce((acc, curr) => acc + parseFloat(curr.price), 0);
            document.getElementById('cart-total').innerText = `Total: $${total}`;
        }

        async function checkout() {
            if (cart.length === 0) return alert("Carrinho vazio!");
            
            const content = {
                embeds: [{
                    title: "Novo Pedido!",
                    description: `Comprador: ${currentUser.user_metadata.nome_ingame}\nTel: ${currentUser.user_metadata.tel_ingame}`,
                    fields: cart.map(i => ({ name: i.name, value: `$${i.price}`, inline: true })),
                    color: 5814783
                }]
            };

            await fetch(DISCORD_WEBHOOK, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(content)
            });

            alert("Pedido enviado para o Discord!");
            cart = [];
            updateCartUI();
        }

        function logout() { location.reload(); }
    </script>
</body>
</html>
